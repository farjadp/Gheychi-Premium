# توکن بات تلگرام - از @BotFather بگیر
BOT_TOKEN=your_telegram_bot_token_here

# مسیر ذخیره فایل‌های دانلود شده (موقت)
DOWNLOAD_DIR=downloads

# حداکثر حجم فایل به مگابایت (تلگرام بات‌ها max 50MB رایگان دارن)
MAX_FILE_SIZE_MB=50

# مسیر ذخیره تنظیمات و لاگ‌های پنل مدیریت
DATA_DIR=data

# پسورد پنل مدیریت وب - اگر خالی باشد، پنل بدون پسورد باز می‌شود
ADMIN_PASSWORD=change_me

# آیدی یا لینک پشتیبانی - مثال: @gheychi_support یا https://t.me/gheychi_support
SUPPORT_CONTACT=@gheychi_support
