# توکن بات تلگرام - از @BotFather بگیر
BOT_TOKEN=your_telegram_bot_token_here

# مسیر ذخیره فایل‌های دانلود شده (موقت)
DOWNLOAD_DIR=downloads

# حداکثر حجم فایل به مگابایت
MAX_FILE_SIZE_MB=50

# مسیر ذخیره تنظیمات و لاگ‌های پنل مدیریت
DATA_DIR=data

# پسورد پنل مدیریت وب
ADMIN_PASSWORD=change_me

# آیدی یا لینک پشتیبانی
SUPPORT_CONTACT=@gheychi_support

# کوکی‌های هر پلتفرم (اختیاری - برای محتوای نیاز به لاگین)
# هر کدام مسیر فایل cookies.txt مربوط به اون پلتفرم رو نشون میده
COOKIES_YOUTUBE=/data/cookies_youtube.txt
COOKIES_INSTAGRAM=/data/cookies_instagram.txt
COOKIES_TWITTER=/data/cookies_twitter.txt
COOKIES_TIKTOK=/data/cookies_tiktok.txt
COOKIES_FACEBOOK=/data/cookies_facebook.txt
COOKIES_SOUNDCLOUD=/data/cookies_soundcloud.txt
COOKIES_VIMEO=/data/cookies_vimeo.txt

# کوکی عمومی (fallback اگر کوکی اختصاصی پلتفرم نبود)
# COOKIES_FILE=/data/cookies.txt

# ---- روش جایگزین برای Railway ----
# به جای آپلود فایل، محتوای cookies.txt را base64 کن و اینجا بذار
# در startup خودکار decode و ذخیره می‌شه
# COOKIES_YOUTUBE_B64=<base64 encoded content of cookies_youtube.txt>
# COOKIES_INSTAGRAM_B64=<base64 encoded content>
# COOKIES_TWITTER_B64=<base64 encoded content>
# COOKIES_TIKTOK_B64=<base64 encoded content>
# COOKIES_FACEBOOK_B64=<base64 encoded content>

# تنظیمات مربوط به API کبالت و RapidAPI (معماری دولایه)
USE_COBALT_API=True
# چنانچه سرور عمومی دچار محدودیت شد، می‌توانید آدرس یک نمونه (Instance) دیگر از کبالت را در اینجا تنظیم کنید.
COBALT_API_URL=https://api.cobalt.tools/

# تنظیمات اکانت تجاری RapidAPI (در صورت فعال‌سازی، دانلودهای توییتر از اینجا عبور می‌کنند)
USE_RAPIDAPI=False
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_HOST=twitter-video-downloader.p.rapidapi.com

# --- Stripe Payment Settings ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
